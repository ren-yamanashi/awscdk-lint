{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "incremental": false,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "types": ["vite-plus/test/globals"],
    "rootDir": ".",
    "outDir": "./dist",
    "module": "ESNext",
    "moduleResolution": "bundler"
  },
  "include": ["src", "scripts", "*.config.ts"],
  "exclude": ["dist", "node_modules"]
}
