{
  "name": "@eslint-plugin-awscdk/example-eslint",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "lint": "pnpm run eslint:esm & pnpm run eslint:cjs && pnpm run oxlint",
    "eslint:esm": "eslint --config eslint.config.ts",
    "eslint:cjs": "eslint --config eslint.config.cts",
    "oxlint": "oxlint --format=unix"
  },
  "dependencies": {
    "aws-cdk-lib": "latest",
    "constructs": "latest"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.13",
    "eslint": "^10.0.0",
    "eslint-plugin-awscdk": "workspace:*",
    "oxlint": "^1.69.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0"
  }
}
