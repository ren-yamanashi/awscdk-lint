{
  "name": "eslint-plugin-awscdk",
  "version": "4.3.3",
  "description": "eslint plugin for AWS CDK projects",
  "keywords": [
    "aws",
    "aws-cdk",
    "eslint",
    "eslint-plugin",
    "eslint-plugin-awscdk",
    "typescript"
  ],
  "homepage": "https://awscdk-lint.dev/",
  "license": "MIT",
  "author": {
    "name": "ren-yamanashi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ren-yamanashi/eslint-plugin-awscdk.git"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "types": "./dist/index.d.mts",
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack": "vp pack",
    "test": "vp test --run"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.10.13",
    "@typescript-eslint/parser": "^8.61.0",
    "@typescript-eslint/rule-tester": "^8.61.0",
    "@typescript-eslint/utils": "^8.61.0",
    "@voidzero-dev/vite-plus-core": "^0.1.11",
    "eslint": "^10.0.0",
    "secretlint": "^13.0.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.61.0",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=4.8.4 <6.1.0"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "packageManager": "pnpm@10.29.3"
}
