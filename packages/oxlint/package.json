{
  "name": "oxlint-plugin-awscdk",
  "version": "0.1.4",
  "description": "Oxlint plugin for AWS CDK",
  "keywords": [
    "aws",
    "aws-cdk",
    "oxlint",
    "oxlint-plugin",
    "oxlint-plugin-awscdk",
    "typescript"
  ],
  "homepage": "https://awscdk-lint.dev/",
  "license": "MIT",
  "author": {
    "name": "ren-yamanashi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ren-yamanashi/awscdk-lint.git"
  },
  "files": [
    "dist",
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    "types": "./dist/index.d.mts",
    "require": {
      "types": "./dist/index.d.cts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack": "vp pack",
    "test": "vp test --run"
  },
  "dependencies": {
    "@typescript/native-preview": "7.0.0-dev.20260516.1",
    "corsa-oxlint": "^0.52.0",
    "oxlint-tsgolint": "^0.24.0"
  },
  "devDependencies": {
    "@oxlint/plugins": "^1.71.0",
    "@types/node": "^24.10.13",
    "@voidzero-dev/vite-plus-core": "^0.1.11",
    "oxlint": "^1.71.0",
    "typescript": "^6.0.2",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "oxlint": "^1.71.0"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "packageManager": "pnpm@10.29.3"
}
