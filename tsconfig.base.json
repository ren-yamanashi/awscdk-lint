{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["ESNext"],
    "incremental": false,
    "declaration": true,
    "sourceMap": true,
    "declarationMap": true,
    "removeComments": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler"
  }
}
