{
  "name": "eslint-cdk-plugin",
  "version": "3.4.8",
  "description": "eslint plugin for AWS CDK projects",
  "keywords": [
    "aws",
    "cdk",
    "eslint",
    "eslint-plugin",
    "eslintplugin"
  ],
  "homepage": "https://eslint-cdk-plugin.dev/",
  "license": "MIT",
  "author": {
    "name": "ren-yamanashi"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ren-yamanashi/eslint-plugin-awscdk.git"
  },
  "bin": {
    "migrate-cdk-plugin": "./bin/index.mjs"
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!src/__tests__",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    "types": "./dist/index.d.ts",
    "require": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.cjs"
    },
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "pack": "vp pack",
    "check": "vp check",
    "test": "vp test --run",
    "docs": "vp run -F @eslint-plugin-awscdk/docs"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@secretlint/secretlint-rule-preset-recommend": "latest",
    "@types/node": "latest",
    "@typescript-eslint/parser": "^8.58.0",
    "@typescript-eslint/rule-tester": "^8.48.1",
    "@typescript-eslint/utils": "^8.48.1",
    "@voidzero-dev/vite-plus-core": "^0.1.11",
    "commander": "^14.0.2",
    "consola": "^3.4.2",
    "eslint": "^10.0.0",
    "secretlint": "^11.2.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "latest",
    "vite-plus": "^0.1.11"
  },
  "peerDependencies": {
    "eslint": "^8.57.0 || ^9.0.0 || ^10.0.0",
    "typescript": ">=4.8.4 <6.1.0"
  },
  "engines": {
    "node": "^18.18.0 || ^20.9.0 || >=21.1.0"
  },
  "packageManager": "pnpm@10.29.3"
}
